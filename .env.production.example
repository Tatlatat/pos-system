# ============================================================================
# Enterprise POS & Inventory Management System — Production Environment
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================================

# Database
DATABASE_URL=postgresql://pos_user:pos_password@localhost:5432/pos_db

# JWT — Generate strong keys:
#   openssl rand -hex 64   (for JWT_SECRET)
#   openssl rand -hex 64   (for JWT_REFRESH_SECRET)
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-hex-string
JWT_REFRESH_EXPIRES_IN=7d

# Redis (optional, for rate limiting + token storage)
REDIS_URL=redis://:redis_pass@localhost:6379

# Backend
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=https://yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
